{
  "name": "afk-discord-bot",
  "version": "1.0.0",
  "description": "A simple Discord AFK bot that stays online and responds when someone mentions an AFK user",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop ecosystem.config.cjs",
    "logs": "pm2 logs afk-bot",
    "test": "node --test"
  },
  "dependencies": {
    "@discordjs/voice": "^0.17.0",
    "discord.js": "^14.16.2",
    "dotenv": "^16.4.2"
  },
  "devDependencies": {
    "pm2": "^5.4.2"
  }
}
